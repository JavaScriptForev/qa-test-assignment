{
  "name": "qa-test-assignment",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "test": "npx playwright test",
    "test:stable": "npx playwright test --workers=1 --retries=5 --timeout=180000",
    "test:headed": "npx playwright test --headed --workers=1 --retries=5",
    "test:debug": "npx playwright test --debug --workers=1",
    "report": "npx playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.13.2",
    "typescript": "~6.0.2"
  }
}
